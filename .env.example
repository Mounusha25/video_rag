# Copy to .env and fill in your values. Do not commit .env.

# --- MongoDB ---
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@treehacks2026.afbqken.mongodb.net/
MONGODB_DB=TreeHacks2026

# --- Optional API key guard (if set, callers must send X-API-Key header) ---
# API_KEY=your-secret-key

# --- Modal (GPU inference) ---
# Get these from: https://modal.com/settings/tokens
MODAL_TOKEN_ID=ak-your-token-id
MODAL_TOKEN_SECRET=as-your-token-secret

# --- YouTube Data API v3 (free video discovery) ---
# Get a key at: https://console.cloud.google.com/ -> APIs & Services -> YouTube Data API v3
# Free quota: 10,000 units/day (~100 searches/day)
YOUTUBE_API_KEY=your-youtube-data-api-key

# Note: DuckDuckGo search is also used as a free fallback (no key needed)
